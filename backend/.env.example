# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────
# MongoDB Atlas (recommended for production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/raksha-farms?retryWrites=true&w=majority

# Local MongoDB
# MONGO_URI=mongodb://localhost:27017/raksha-farms

# ── Auth ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret_in_production

ADMIN_USERNAME=admin
# Generate hash: node -e "const b=require('bcryptjs'); b.hash('your_password',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$10$XFE/N2GpVBa4z1A5YmV0BOkdMD/YBvAu.V5e.i9WuIVKLrUQ5Ld3m

# ── Frontend ────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── WhatsApp ────────────────────────────────────────────────────────
# Owner's WhatsApp number (include country code, no + or spaces)
OWNER_WHATSAPP=919876543210
OWNER_UPI_ID=rakshafarms@upi
